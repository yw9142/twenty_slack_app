{
  "name": "daou-slack-agent",
  "version": "0.1.41",
  "description": "Slack-driven CRM automation app for Daou Data on Twenty",
  "author": "Daou Data Virtualization Division Demo",
  "homepage": "https://www.daoudata.co.kr",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yw9142/twenty_slack_app.git"
  },
  "bugs": {
    "url": "https://github.com/yw9142/twenty_slack_app/issues"
  },
  "engines": {
    "node": "^24.5.0",
    "npm": "please-use-yarn",
    "yarn": ">=4.0.2"
  },
  "keywords": [
    "twenty-app"
  ],
  "packageManager": "yarn@4.9.2",
  "scripts": {
    "twenty": "twenty",
    "build": "yarn twenty build",
    "deploy:linux-safe": "node scripts/twenty-linux-deploy.mjs",
    "lint": "oxlint -c .oxlintrc.json .",
    "lint:fix": "oxlint --fix -c .oxlintrc.json .",
    "slack-proxy:start": "node slack-proxy/server.mjs",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "RUN_TWENTY_INTEGRATION_TESTS=true vitest run"
  },
  "dependencies": {
    "twenty-client-sdk": "0.8.0",
    "twenty-sdk": "0.8.0"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/react": "^19.0.0",
    "oxlint": "^0.16.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^4.2.1",
    "vitest": "^3.1.1"
  }
}
